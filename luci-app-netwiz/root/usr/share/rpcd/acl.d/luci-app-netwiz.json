{
    "luci-app-netwiz": {
        "description": "Grant access to netwiz configuration scripts",
        "read": {
            "rpc-methods": {
                "netwiz": [ "confirm" ]
            }
        },
        "write": {
            "rpc-methods": {
                "netwiz": [ "set_network", "confirm" ]
            }
        }
    }
}
